# Aldoc proxy auth (required unless SKIP_API_AUTH=1)
API_KEY=
API_SECRET=

# WooCommerce (InterCars product sync)
WP_CK_PROD=
WP_CS_PROD=
WP_CK_LOCAL=
WP_CS_LOCAL=

# Redis (InterCars token cache + BullMQ for CSV import)
# Local Mac Redis usually has NO password — leave empty for productionLocal dev.
# Production server (emrearas.nl): REDIS_PASSWORD=pc2024
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://:password@localhost:6379

# InterCars API (Postman: baseUrl + Authorize)
IC_API_BASE_URL=https://api.webapi.intercars.eu/ic
IC_TOKEN_URL=https://is.webapi.intercars.eu/oauth2/token?grant_type=client_credentials&scope=allinone
IC_USE_SANDBOX=0
IC_PROD_CLIENT_ID=
IC_PROD_SECRET=
IC_SANDBOX_CLIENT_ID=
IC_SANDBOX_SECRET=
# IC_SHIP_TO=
# IC_PRICING_LOCATION=KOM

# Autodoc scrape (optional Browserless for Cloudflare)
BROWSERLESS_TOKEN=
# BROWSERLESS_URL=https://production-sfo.browserless.io/content

# AutoPartner CustomerAPI (REST/JSON wrapper over SOAP service)
# Production REST base:
#   https://customerapi.autopartner.dev/CustomerAPI.svc/rest
# Test REST base (may require separate test account — AP can revoke test access):
#   https://customerapitest.autopartner.dev/CustomerAPI.svc/rest
# HTTP 403 "Access Forbidden" = account has no permission to call Web Service (AP docs).
# Wrong password usually returns ErrorCode 02 inside a normal JSON response, not HTTP 403.
AUTOPARTNER_BASE_URL=https://customerapi.autopartner.dev/CustomerAPI.svc/rest
AUTOPARTNER_CLIENT_CODE=
AUTOPARTNER_WS_PASSWORD=
# Default currency when currencyCode isn't provided
AUTOPARTNER_CURRENCY=EUR
# Default warehouse/branch when departamentCode isn't provided (AP spelling)
AUTOPARTNER_DEPARTAMENT_CODE=CN
# Either provide MD5 hash (preferred) OR plaintext (will be hashed in-memory).
# MD5 hash stored in AP system (NOT plaintext)
AUTOPARTNER_CLIENT_PASSWORD_MD5=
# AUTOPARTNER_CLIENT_PASSWORD=

# InterParts Falcon5 WebService (MD5 password auth via doLogin)
INTERPARTS_BASE_URL=http://webservice.interparts.pl:7891/ws/
INTERPARTS_USER_LOGIN=
# MD5 hash of password (preferred) OR plaintext (hashed in-memory)
INTERPARTS_USER_PASSWORD_MD5=
# INTERPARTS_USER_PASSWORD=

# Redis cache TTL for InterParts sessionId (default 3600). Server may expire earlier; ERR_SESSION triggers auto re-login.
# INTERPARTS_SESSION_TTL_SECONDS=3600

# PORT=3000
